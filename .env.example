PORT=3000

# Database (MySQL)
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=govibe
DB_PARAMS=parseTime=true&loc=Local

# Mail (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=false
SMTP_STARTTLS=true
SMTP_INSECURE=false

# Auth (JWT)
JWT_SECRET=
JWT_TTL_MIN=60

# Token periods (minutes)
# Access token validity (default 60 minutes)
ACCESS_TOKEN_PERIOD_MIN=60
# Refresh token validity (default 1440 minutes / 24h)
REFRESH_TOKEN_PERIOD_MIN=1440

# Frontend (Vite)
# Used by `resources/js/config/baseUrl.js` to prefix "/api/*" requests.
VITE_BASE_URL=http://127.0.0.1:3000
# Optional override (if API is on a different host).
# VITE_API_BASE_URL=http://127.0.0.1:3000
